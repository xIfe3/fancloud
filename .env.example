# Postgres connection string.
#
# Local Postgres (development):
#   postgresql://postgres:YOUR_PASSWORD@localhost:5432/fancloud
#
# Neon (production / Vercel): use the POOLED connection string from the Neon dashboard.
#   postgresql://USER:PASS@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
#
# Never commit a real value in this file — put it in .env.local (gitignored) instead.
DATABASE_URL=

# Long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Backstage password — bcrypt hash, base64-encoded.
# Generate with: npm run admin:hash "your password here"
# (We store it base64-encoded because Next.js's env loader corrupts the raw
# bcrypt format. Our auth decodes it at runtime — paste the value as-is.)
ADMIN_PASSWORD_HASH=

# --- SMTP (contact form email forwarding) ---
# Used to forward contact-form messages to your support inbox.
# Get these from Spaceship → your domain → Mailbox → SMTP / Email Client settings.
#
# Typical Spaceship SpaceMail settings (verify in your panel):
#   SMTP_HOST=smtppro.zoho.com   (or mail.spacemail.com, etc.)
#   SMTP_PORT=465                (SSL) — or 587 for STARTTLS
#   SMTP_SECURE=true             (true for 465, false for 587)
#   SMTP_USER=hello@yourdomain.com
#   SMTP_PASSWORD=<the password from Spaceship>
#   SMTP_FROM=hello@yourdomain.com   (must match SMTP_USER on most providers)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# If your SMTP password contains `$` characters, Next.js's env loader will
# corrupt it the same way it corrupts bcrypt hashes. In that case, leave
# SMTP_PASSWORD blank and use the base64-encoded form instead:
#   node -e "console.log(Buffer.from('YOUR_PASSWORD').toString('base64'))"
# Then paste the result here:
SMTP_PASSWORD_B64=

# --- Vercel Blob (image uploads for the backstage event editor) ---
# Get this from Vercel dashboard → your project → Storage → your Blob store
# → ".env.local" tab → copy BLOB_READ_WRITE_TOKEN.
# On Vercel itself, this env var is auto-injected when the project is linked
# to a Blob store, so you don't need to set it manually in Vercel's UI.
BLOB_READ_WRITE_TOKEN=
